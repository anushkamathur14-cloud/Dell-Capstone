APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adaptive_experiments
ENABLE_PGVECTOR=false

# LangSmith (observability)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dell-capstone-adaptive-exp-agent
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dell-capstone-validation

BENCHMARK_DATA_DIR=synthetic_env/benchmarks/generated_sanity_calibrated

# Azure OpenAI (Microsoft Foundry) — deployment names in your Azure resource
# Use the exact endpoint from Azure AI Foundry (often *.openai.azure.com, not cognitiveservices)
AZURE_OPENAI_ENDPOINT=https://hirecrit.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=

VALIDATION_LLM_MODEL=capstone-mini
GENERATION_LLM_MODEL=capstone-standard
STAT_LLM_MODEL=capstone-code
ENABLE_VALIDATION_LLM=false

# Causal subagent (ReAct + tools + local sandbox). false = programmatic stub only (CI default).
ENABLE_CAUSAL_AGENT_LOOP=false
PROMPT_DISCLOSURE_LEVEL=standard
CAUSAL_AGENT_MAX_ITERATIONS=6

# Opt-in live Azure smoke (scripts/smoke_azure_openai.py); never set in CI
RUN_AZURE_OPENAI_SMOKE=false
