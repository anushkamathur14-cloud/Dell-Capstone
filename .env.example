APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adaptive_experiments
ENABLE_PGVECTOR=false
# LangSmith (observability) — enable when you want traces sent to smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dell-capstone-adaptive-exp-agent
# Back-compat with older LangChain env names (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dell-capstone-validation
BENCHMARK_DATA_DIR=synthetic_env/benchmarks/generated_sanity_calibrated
ENABLE_VALIDATION_LLM=false
VALIDATION_LLM_MODEL=gpt-4o-mini
