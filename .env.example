APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adaptive_experiments
ENABLE_PGVECTOR=false

# --- Azure AI Foundry (recommended for capstone) ---
# See docs/AZURE_FOUNDRY.md for role → deployment mapping.
LLM_PROVIDER=auto
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Direct OpenAI (optional if not using Azure)
OPENAI_API_KEY=

# Deployment / model names (must match Foundry deployments on Azure)
VALIDATION_LLM_MODEL=gpt-4o-mini
RECOMMENDATION_LLM_MODEL=gpt-4o-mini
GENERATION_LLM_MODEL=gpt-4o
STAT_CAUSAL_LLM_MODEL=gpt-4.1
ORCHESTRATION_LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

ENABLE_VALIDATION_LLM=false
ENABLE_RECOMMENDATION_LLM=false
ENABLE_RECOMMENDATION_LLM_LOOP=false

# LangSmith tracing (optional; separate from Azure keys)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dell-capstone-validation

BENCHMARK_DATA_DIR=synthetic_env/benchmarks/generated_sanity_calibrated
RECOMMENDATION_VARIANCE_LAMBDA=0.2
RECOMMENDATION_UNCERTAINTY_WEIGHT=0.2
ENABLE_CAUSAL_SANDBOX=true
SANDBOX_PROVIDER=daytona
DAYTONA_API_KEY=
CORS_ALLOW_ORIGINS=*
